{
  "name": "@authorsoftware/config",
  "version": "1.0.0-alpha.3",
  "description": "Author application configuration utility.",
  "bin": {
    "author-verify": "./verify.js",
    "author-icon": "./icon.js",
    "author-instructions": "./agent.js",
    "author-example": "./example.js"
  },
  "keywords": [
    "author",
    "config",
    "author-cfg"
  ],
  "license": "MIT",
  "author": "Author Software Inc.",
  "repository": {
    "type": "git",
    "url": "https://github.com/author/author-cfg-tool"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "npx:instructions": "npm exec --yes author-instructions --",
    "npx:test": "npm exec --yes author-verify --",
    "npx:icon": "npm exec --yes author-icon --",
    "npx:create-example": "npm exec --yes author-example --"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "ajv": "^8.18.0",
    "image-size": "^2.0.2",
    "jimp": "^0.22.12"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
